diff --git a/lazycat-entrypoint.sh b/lazycat-entrypoint.sh
new file mode 100755
index 0000000..1a68e39
--- /dev/null
+++ b/lazycat-entrypoint.sh
@@ -0,0 +1,20 @@
+#!/usr/bin/env bash
+# Lazycat-flavored entrypoint for bilibili-rag.
+#
+# 1. Ensure persistent dirs exist. Lazycat binds:
+#      /lzcapp/var/persist -> /app/data   (sqlite + chroma)
+#      /lzcapp/var/logs    -> /app/logs   (optional, see manifest)
+# 2. App config comes from env vars injected by lzc-manifest.yml. The
+#    upstream Settings class reads DASHSCOPE_API_KEY / OPENAI_BASE_URL /
+#    LLM_MODEL / EMBEDDING_MODEL etc. directly via pydantic_settings.
+# 3. supervisord launches uvicorn + node server.js + nginx, exec'd as PID 1.
+
+set -euo pipefail
+
+mkdir -p /app/data /app/logs
+
+# pydantic_settings reads from env first, then .env. We rely on env vars
+# only — no .env file is created. Defaults from app/config.py are kept
+# intact (sqlite path, chroma dir).
+
+exec /usr/bin/supervisord -c /app/supervisord.conf
diff --git a/nginx.conf b/nginx.conf
new file mode 100644
index 0000000..16f5d3c
--- /dev/null
+++ b/nginx.conf
@@ -0,0 +1,79 @@
+# Nginx fronts the lazycat-pixelle/bilibili-rag combo container.
+#
+#   /api/    -> FastAPI (127.0.0.1:8000), /api prefix stripped
+#   /        -> Next.js standalone server (127.0.0.1:3000)
+#
+# The Next.js bundle was built with NEXT_PUBLIC_API_URL=/api so the browser
+# always hits this nginx, never localhost:8000. WebSocket-style upgrade
+# headers are forwarded for safety even though the production app does not
+# currently use WebSockets.
+
+worker_processes auto;
+pid /run/nginx.pid;
+error_log /dev/stderr warn;
+
+events {
+    worker_connections 1024;
+}
+
+http {
+    include /etc/nginx/mime.types;
+    default_type application/octet-stream;
+
+    sendfile on;
+    keepalive_timeout 65;
+    server_tokens off;
+
+    access_log /dev/stdout;
+
+    # ASR fallback path uploads audio (~tens of MB). Allow up to 200 MiB.
+    client_max_body_size 200M;
+
+    # Long-running ASR/RAG requests need generous proxy timeouts.
+    proxy_connect_timeout 60s;
+    proxy_send_timeout    600s;
+    proxy_read_timeout    600s;
+
+    map $http_upgrade $connection_upgrade {
+        default upgrade;
+        ''      close;
+    }
+
+    server {
+        listen 80 default_server;
+        listen [::]:80 default_server;
+
+        # FastAPI under /api/* (strip the /api prefix; trailing slash on
+        # proxy_pass makes nginx rewrite /api/foo -> /foo).
+        location /api/ {
+            proxy_pass http://127.0.0.1:8000/;
+            proxy_http_version 1.1;
+            proxy_set_header Host              $host;
+            proxy_set_header X-Real-IP         $remote_addr;
+            proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
+            proxy_set_header X-Forwarded-Proto $scheme;
+            proxy_set_header Upgrade           $http_upgrade;
+            proxy_set_header Connection        $connection_upgrade;
+            proxy_buffering off;
+        }
+
+        # Health endpoint served by nginx itself for fast checks.
+        location = /health {
+            access_log off;
+            add_header Content-Type text/plain;
+            return 200 "ok\n";
+        }
+
+        # Everything else -> Next.js
+        location / {
+            proxy_pass http://127.0.0.1:3000;
+            proxy_http_version 1.1;
+            proxy_set_header Host              $host;
+            proxy_set_header X-Real-IP         $remote_addr;
+            proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
+            proxy_set_header X-Forwarded-Proto $scheme;
+            proxy_set_header Upgrade           $http_upgrade;
+            proxy_set_header Connection        $connection_upgrade;
+        }
+    }
+}
diff --git a/supervisord.conf b/supervisord.conf
new file mode 100644
index 0000000..a825888
--- /dev/null
+++ b/supervisord.conf
@@ -0,0 +1,47 @@
+; supervisord runs the three processes that make up the lazycat
+; bilibili-rag container: FastAPI backend, Next.js standalone server,
+; and nginx (fronting both, listening on :80).
+
+[supervisord]
+nodaemon=true
+user=root
+logfile=/dev/null
+logfile_maxbytes=0
+pidfile=/var/run/supervisord.pid
+
+[program:backend]
+command=/opt/venv/bin/uvicorn app.main:app --host 127.0.0.1 --port 8000 --no-access-log
+directory=/app
+autorestart=true
+stopasgroup=true
+killasgroup=true
+priority=10
+environment=PYTHONUNBUFFERED="1"
+stdout_logfile=/dev/stdout
+stdout_logfile_maxbytes=0
+stderr_logfile=/dev/stderr
+stderr_logfile_maxbytes=0
+
+[program:frontend]
+command=node server.js
+directory=/app/frontend
+autorestart=true
+stopasgroup=true
+killasgroup=true
+priority=20
+environment=PORT="3000",HOSTNAME="127.0.0.1",NODE_ENV="production",NEXT_TELEMETRY_DISABLED="1"
+stdout_logfile=/dev/stdout
+stdout_logfile_maxbytes=0
+stderr_logfile=/dev/stderr
+stderr_logfile_maxbytes=0
+
+[program:nginx]
+command=/usr/sbin/nginx -g "daemon off;"
+autorestart=true
+stopasgroup=true
+killasgroup=true
+priority=30
+stdout_logfile=/dev/stdout
+stdout_logfile_maxbytes=0
+stderr_logfile=/dev/stderr
+stderr_logfile_maxbytes=0
